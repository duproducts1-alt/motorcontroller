<project>
    <name>Motor Controller</name>
    <description>STM32CubeIDE project for Motor Controller</description>
    <version>4.0.0</version>
    <projectType>STM32CubeIDE</projectType>
    <buildCommand>make</buildCommand>
    <linkerFile>STM32F1xx.ld</linkerFile>
    <includePath>
        <path>Inc</path>
        <path>Src</path>
        <path>Drivers</path>
    </includePath>
    <sourceFiles>
        <file>main.c</file>
        <file>motor.c</file>
        <file>motor.h</file>
        <file>stm32f1xx_it.c</file>
    </sourceFiles>
    <compilerFlags>
        <flag>-Wall</flag>
        <flag>-O2</flag>
    </compilerFlags>
</project>